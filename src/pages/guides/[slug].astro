---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { guides, SITE_NAME, SITE_URL, tools } from '../../data/site';
export function getStaticPaths() { return guides.map((guide) => ({ params: { slug: guide.slug }, props: { guide } })); }
const { guide } = Astro.props;
const path = `/guides/${guide.slug}/`;
const schema = [
  { '@context': 'https://schema.org', '@type': 'Article', headline: guide.title, description: guide.description, mainEntityOfPage: new URL(path, SITE_URL).href, author: { '@type': 'Organization', name: SITE_NAME }, publisher: { '@type': 'Organization', name: SITE_NAME }, datePublished: '2026-07-21', dateModified: '2026-07-22' },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: SITE_NAME, item: SITE_URL }, { '@type': 'ListItem', position: 2, name: 'Guides', item: new URL('/guides/', SITE_URL).href }, { '@type': 'ListItem', position: 3, name: guide.title, item: new URL(path, SITE_URL).href }] },
];
---
<BaseLayout title={guide.title} description={guide.description} path={path} type="article" schema={schema}>
  <article class="guide-page">
    <header class="guide-header"><div class="section-shell"><nav class="breadcrumbs" aria-label="Breadcrumb"><a href="/">Home</a><span>/</span><a href="/guides/">Guides</a></nav><p class="kicker mint">{guide.audience} · {guide.readTime} read</p><h1>{guide.title}</h1><p>{guide.description}</p></div></header>
    <div class="guide-layout section-shell"><aside><strong>In this guide</strong>{guide.sections.map((section) => <a href={`#${section.heading.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}>{section.heading}</a>)}<div><span>Private workspace</span><p>Check a photo without uploading it.</p><a href="/photo-privacy-check/">Open scanner →</a></div></aside><div class="guide-prose">{guide.sections.map((section, index) => <section id={section.heading.toLowerCase().replace(/[^a-z0-9]+/g, '-')}><span class="section-number">0{index + 1}</span><h2>{section.heading}</h2>{section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}{section.checklist && <div class="checklist"><h3>Review checklist</h3><ul>{section.checklist.map((item) => <li>✓ {item}</li>)}</ul></div>}</section>)}<div class="guide-next"><p class="kicker">Put it into practice</p><h2>Check the exact photo you plan to share</h2><p>The scanner works locally and does not add your filename or extracted metadata to an analytics request.</p><a class="primary-button" href={`/${tools[0].slug}/`}>Open the privacy check</a></div></div></div>
  </article>
</BaseLayout>
